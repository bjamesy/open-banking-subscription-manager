# Copy to .env and fill in. Never commit .env.

# Google Sign-In client ID (architecture §6.4) — public by design, not a
# secret (sent in every Google sign-in request). Omit to hide the Google
# button entirely; the backend's GOOGLE_CLIENT_ID (backend/.env) is what
# actually verifies sign-ins.
VITE_GOOGLE_CLIENT_ID=
