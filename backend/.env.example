# Copy to .env and fill in. Never commit .env.

APP_ENV=development

# Database. Local dev can use sqlite; production uses Postgres.
DATABASE_URL=postgresql://subtrack:subtrack@localhost:5432/subtrack
# DATABASE_URL=sqlite:///./subtrack.db

# Plaid. In the cresidential project the secret was named PLAID_SANDBOX_SECRET_KEY;
# here it is PLAID_SECRET. PLAID_ENV is sandbox | production.
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# SubTrack targets Canada. Verify Plaid institution coverage for CA (architecture §6.2)
# before committing to production. Comma-separated ISO country codes.
PLAID_COUNTRY_CODES=CA
PLAID_PRODUCTS=transactions
PLAID_CLIENT_NAME=SubTrack

# Anthropic (AI-assisted detection, Phase 2). Model choice is an open question
# (architecture §6.5); override here if a cheaper model is preferred.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Fernet key used to encrypt Plaid access tokens at rest.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Auth (architecture §6.4)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
